#include <WiFi.h>
#include <HTTPClient.h>
#include <WiFiClientSecure.h>
#include <ArduinoJson.h>
#include <Wire.h>
#include <Adafruit_GFX.h>
#include <Adafruit_SH110X.h>
#include "time.h"
#include <TOTP.h>
#include <Preferences.h>
#include <RtcDS3231.h>

// --- USER CONFIGURATION (EDIT THIS) ---
const char* ssid     = "iPhone";
const char* password = "Rohan123";
// Your Vercel URL + /api/fetch
// Example: "https://esp32-cloud-backend.vercel.app/api/fetch"
const char* serverUrl = "https://esp32-cloud-backend-ien0egkwm-rohan-patels-projects-f8b9837d.vercel.app/api/fetch";

// --- PINS ---
#define TOUCH_NEXT_PIN 13
#define TOUCH_PREV_PIN 12
#define TOUCH_SYNC_PIN 33
#define LED_PIN 2
#define I2C_SDA 21        // Shared by OLED and RTC
#define I2C_SCL 22        // Shared by OLED and RTC
#define i2c_Address 0x3c  // OLED Address

// --- OBJECTS ---
Adafruit_SH1106G display = Adafruit_SH1106G(128, 64, &Wire, -1);
Preferences preferences;
RtcDS3231<TwoWire> Rtc(Wire);

// --- GLOBALS ---
struct Account {
  String name;
  String issuer;
  String secret;
  uint8_t hmacKey[20];
  int keyLength;
};
Account myAccounts[10];
int accountCount = 0;
int currentAccountIndex = 0;

// --- BASE32 DECODER ---
int base32Decode(String encoded, uint8_t *result) {
  int buffer = 0;
  int bitsLeft = 0;
  int count = 0;
  const char *ptr = encoded.c_str();
  for (; *ptr; ++ptr) {
    uint8_t val;
    char c = toupper(*ptr);
    if (c >= 'A' && c <= 'Z') val = c - 'A';
    else if (c >= '2' && c <= '7') val = c - '2' + 26;
    else continue;
    buffer = (buffer << 5) | val;
    bitsLeft += 5;
    if (bitsLeft >= 8) {
      result[count++] = (buffer >> (bitsLeft - 8)) & 0xFF;
      bitsLeft -= 8;
    }
  }
  return count;
}

void parseAccounts(String jsonPayload) {
  JsonDocument doc;
  DeserializationError error = deserializeJson(doc, jsonPayload);
  if (!error) {
    accountCount = 0;
    for (JsonObject v : doc.as<JsonArray>()) {
      if(accountCount >= 10) break;
      myAccounts[accountCount].name = v["name"].as<String>();
      myAccounts[accountCount].issuer = v["issuer"].as<String>();
      myAccounts[accountCount].secret = v["secret"].as<String>();
      myAccounts[accountCount].keyLength = base32Decode(
        myAccounts[accountCount].secret,
        myAccounts[accountCount].hmacKey
      );
      accountCount++;
    }
  }
}

// --- SYNC FUNCTION ---
void performCloudSync() {
  display.clearDisplay();
  display.setCursor(0, 0);
  display.println("Connecting WiFi...");
  display.display();

  // 1. Connect WiFi
  WiFi.begin(ssid, password);
  int retry = 0;
  while (WiFi.status() != WL_CONNECTED && retry < 15) {
    delay(500);
    digitalWrite(LED_PIN, !digitalRead(LED_PIN));
    retry++;
  }
  digitalWrite(LED_PIN, LOW);

  if (WiFi.status() != WL_CONNECTED) {
    display.println("WiFi Failed!");
    display.display();
    delay(1000);
    return;
  }

  display.println("WiFi OK! Syncing...");
  display.display();

  // 2. Sync Time (NTP -> RTC)
  configTime(0, 0, "pool.ntp.org", "time.google.com");
  struct tm timeinfo;
  if(getLocalTime(&timeinfo)){
    time_t now;
    time(&now);
    struct tm * t = localtime(&now);
    RtcDateTime accurateTime(
      t->tm_year + 1900, t->tm_mon + 1, t->tm_mday,
      t->tm_hour, t->tm_min, t->tm_sec
    );
    Rtc.SetDateTime(accurateTime);
    Serial.println("RTC Updated!");
  }

  // 3. Sync Accounts
  WiFiClientSecure client;
  client.setInsecure();
  HTTPClient http;

  preferences.begin("2fa_storage", false);
  String cachedJson = preferences.getString("json", "");

  if (http.begin(client, serverUrl)) {
    int httpCode = http.GET();
    if (httpCode > 0) {
      String payload = http.getString();
      if (payload != cachedJson && payload.length() > 10) {
        preferences.putString("json", payload);
        parseAccounts(payload);
        display.println("New Data Saved!");
      } else {
        display.println("Already Updated.");
      }
    } else {
      display.println("Server Error!");
    }
    http.end();
  }
  preferences.end();
  display.display();
  delay(1000);
}

// --- SETUP ---
void setInternalTimeFromRTC() {
  RtcDateTime now = Rtc.GetDateTime();
  struct timeval tv;
  tv.tv_sec = now.Epoch32Time();
  tv.tv_usec = 0;
  settimeofday(&tv, NULL);
}

void setup() {
  Serial.begin(115200);

  // Init Hardware Pins
  pinMode(TOUCH_NEXT_PIN, INPUT);
  pinMode(TOUCH_PREV_PIN, INPUT);
  pinMode(TOUCH_SYNC_PIN, INPUT);
  pinMode(LED_PIN, OUTPUT);

  // --- ROBUST I2C START (STEP 3 FIX) ---
  // 1. Manually Start I2C Bus FIRST
  Wire.begin(I2C_SDA, I2C_SCL);
  delay(100); // Give devices time to wake up

  // 2. Start Display (Critical: Do this before RTC touches the bus)
  display.begin(i2c_Address, true);
  display.clearDisplay();
  display.setTextColor(SH110X_WHITE);
  display.setCursor(0,0);
  display.println("Booting System...");
  display.display();
  delay(500); // Wait for display to stabilize

  // 3. Start RTC
  Rtc.Begin();
  if (!Rtc.GetIsRunning()) {
    Serial.println("RTC not running, starting now");
    Rtc.SetIsRunning(true);
  }

  // FORCE TIME SYNC CHECK (If year is wrong, try sync immediately)
  RtcDateTime rtcNow = Rtc.GetDateTime();
  if (rtcNow.Year() < 2024) {
      display.setCursor(0,0);
      display.println("RTC Unset.");
      display.println("Syncing...");
      display.display();
      performCloudSync(); // Force sync on first run
  } else {
      setInternalTimeFromRTC();
      // Show Temp (DS3231 Feature!)
      RtcTemperature temp = Rtc.GetTemperature();
      display.setCursor(0,0);
      display.printf("Temp: %.1f C\n", temp.AsFloatDegC());
      display.println("Loading Keys...");
      display.display();
      delay(1000);
  }

  // LOAD CACHE
  preferences.begin("2fa_storage", false);
  String cachedJson = preferences.getString("json", "");
  if (cachedJson.length() > 0) parseAccounts(cachedJson);
  preferences.end();
}

void loop() {
  if (accountCount == 0) {
    display.clearDisplay();
    display.setCursor(0,0);
    display.println("No Accounts!");
    display.println("Press Sync Btn");
    display.display();

    if (digitalRead(TOUCH_SYNC_PIN) == HIGH) {
        performCloudSync();
    }
    delay(200);
    return;
  }

  // --- BUTTON LOGIC ---
  if (digitalRead(TOUCH_NEXT_PIN) == HIGH) {
    currentAccountIndex++;
    if (currentAccountIndex >= accountCount) currentAccountIndex = 0;
    delay(250);
  }
  if (digitalRead(TOUCH_PREV_PIN) == HIGH) {
    currentAccountIndex--;
    if (currentAccountIndex < 0) currentAccountIndex = accountCount - 1;
    delay(250);
  }

  // --- SYNC BUTTON LOGIC ---
  if (digitalRead(TOUCH_SYNC_PIN) == HIGH) {
    delay(100);
    if (digitalRead(TOUCH_SYNC_PIN) == HIGH) {
       performCloudSync();
       setInternalTimeFromRTC();
    }
  }

  // --- TOTP DISPLAY ---
  time_t now;
  time(&now);
  TOTP totp = TOTP(myAccounts[currentAccountIndex].hmacKey, myAccounts[currentAccountIndex].keyLength);
  char* newCode = totp.getCode(now);
  int secondsRemaining = 30 - (now % 30);

  // LED Flash
  if (secondsRemaining <= 10) {
    if ((millis() / 100) % 2 == 0) digitalWrite(LED_PIN, HIGH);
    else digitalWrite(LED_PIN, LOW);
  } else {
    digitalWrite(LED_PIN, LOW);
  }

  display.clearDisplay();
  display.setTextSize(1);
  display.setTextColor(SH110X_WHITE);
  display.setCursor(0, 0);
  display.printf("%s (%d/%d)", myAccounts[currentAccountIndex].issuer.c_str(), currentAccountIndex+1, accountCount);

  display.setCursor(0, 12);
  display.println(myAccounts[currentAccountIndex].name.substring(0, 15));

  display.setTextSize(2);
  display.setCursor(15, 35);
  String c = String(newCode);
  display.print(c.substring(0,3) + " " + c.substring(3));

  display.fillRect(0, 60, map(secondsRemaining, 0, 30, 0, 128), 4, SH110X_WHITE);

  if (digitalRead(TOUCH_NEXT_PIN) == HIGH) display.fillCircle(124, 30, 3, SH110X_WHITE);
  if (digitalRead(TOUCH_PREV_PIN) == HIGH) display.fillCircle(4, 30, 3, SH110X_WHITE);

  display.display();
}